# =============================================================================
# Supabase Configuration
# =============================================================================
# Get these values from your Supabase project dashboard:
#   1. Go to supabase.com and open your project
#   2. Click "Project Settings" (gear icon) in the left sidebar
#   3. Click "API" under Configuration
#   4. Copy the values below
#
# NEXT_PUBLIC_ prefix means these are safe to use in browser code.
# They're "public" keys — they identify your project but don't grant admin access.
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
